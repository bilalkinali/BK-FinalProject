{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ReverseProxy": {
    "Routes": {
      "salesforce-route": {
        "ClusterId": "salesforce-cluster",
        "Match": {
          "Path": "/api/salesforce/{**catch-all}"
        },
        "Transforms": [
          {
            "PathRemovePrefix": "/api/salesforce"
          }
        ]
      },
      "contentmoderation-route": {
        "ClusterId": "contentmoderation-cluster",
        "Match": {
          "Path": "/api/contentmoderation/{**catch-all}"
        },
        "Transforms": [
          {
            "PathRemovePrefix": "/api/contentmoderation"
          }
        ]
      }
    },
    "Clusters": {
      "salesforce-cluster": {
        "Destinations": {
          "salesforce-destination": {
            "Address": "http://salesforceservice-api:8080/"
          }
        }
      },
      "contentmoderation-cluster": {
        "Destinations": {
          "contentmoderation-destination": {
            "Address": "http://contentmoderationservice-api:8080/"
          }
        }
      }
    }
  }
}
